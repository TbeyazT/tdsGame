{
  "emitLegacyScripts": false,
  "name": "blink",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Client": {
        "$path": "src/client"
      },
      "Shared": {
        "$path": "src/shared",
        "Generate": {
          "$className": "RemoteEvent"
        },
        "GetRecieved": {
          "$className": "RemoteFunction"
        },
        "Packages": {
          "$path": "packages"
        }
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    }
  }
}